---
interface Props {
  name: string;
  ref: string;
  gamme: 'Initiale' | 'Signature';
  image?: string;
  mouvement?: string;
  href: string;
}

const { name, ref: refId, gamme, image, mouvement, href } = Astro.props;
---

<article class="carte-montre">
  <a href={href} class="carte-link" aria-label={`Voir la montre ${name}`}>
    <div class="carte-image">
      {image
        ? <img src={image} alt={`${name} — montre sur mesure bang.`} loading="lazy" />
        : <div class="carte-image-placeholder" aria-hidden="true"></div>
      }
      <span class={`badge badge-${gamme.toLowerCase()}`}>{gamme}</span>
    </div>
    <div class="carte-body">
      <p class="carte-ref">{refId}</p>
      <h3 class="carte-name">{name}</h3>
      {mouvement && <p class="carte-mouvement">{mouvement}</p>}
      <span class="carte-cta">Voir la fiche →</span>
    </div>
  </a>
</article>

<style>
  .carte-montre {
    background: var(--noir-card);
    border: 1px solid rgba(197, 165, 114, 0.15);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .carte-montre:hover {
    border-color: rgba(197, 165, 114, 0.4);
  }

  .carte-link {
    display: block;
    text-decoration: none;
  }

  .carte-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--noir-surface);
  }

  .carte-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .carte-montre:hover .carte-image img {
    transform: scale(1.04);
  }

  .carte-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--noir-surface) 0%, var(--noir-card) 100%);
  }

  .carte-image .badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
  }

  .carte-body {
    padding: 1.25rem;
  }

  .carte-ref {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--gris-muted);
    margin-bottom: 0.25rem;
    max-width: none;
  }

  .carte-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--blanc);
    margin-bottom: 0.375rem;
  }

  .carte-mouvement {
    font-size: 0.8rem;
    color: var(--gris-texte);
    margin-bottom: 0.75rem;
    max-width: none;
  }

  .carte-cta {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--gold);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.03em;
  }
</style>
