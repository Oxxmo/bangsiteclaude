---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Configurer', href: '/configurer' },
  { label: 'Réalisations', href: '/realisations' },
  { label: 'La Maison', href: '/la-maison' },
  { label: 'Le Journal', href: '/journal' },
  { label: 'Le Club', href: '/club' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="bang. — retour à l'accueil">bang.</a>

    <nav class="nav" id="main-nav" aria-label="Navigation principale">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${pathname.startsWith(link.href) ? 'active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="main-nav"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById('hamburger-btn');
  const nav = document.getElementById('main-nav');

  btn?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('nav--open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    btn.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--noir);
    border-bottom: 1px solid rgba(197, 165, 114, 0.15);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-family: 'League Spartan', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--gold);
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gris-texte);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--blanc);
    border-bottom-color: var(--gold);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--blanc);
    transition: opacity 0.2s ease;
  }

  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }

    .nav {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background-color: var(--noir);
      border-bottom: 1px solid rgba(197, 165, 114, 0.15);
      padding: 1.5rem;
      display: none;
    }

    .nav--open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .nav-link {
      font-size: 1rem;
    }
  }
</style>
