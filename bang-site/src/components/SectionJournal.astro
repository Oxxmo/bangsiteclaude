---
interface Props {
  image?: string;
  category: string;
  title: string;
  excerpt: string;
  date: Date;
  readingTime: number;
  href: string;
}

const { image, category, title, excerpt, date, readingTime, href } = Astro.props;

const dateFormatted = date.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  culture: 'Culture',
  style: 'Style',
  atelier: 'Atelier',
  mecanique: 'Mécanique',
};
---

<article class="journal-card">
  <a href={href} class="journal-link">
    <div class="journal-image">
      {image
        ? <img src={image} alt={title} loading="lazy" />
        : <div class="journal-image-placeholder"></div>
      }
      <span class="journal-category">{categoryLabels[category] ?? category}</span>
    </div>
    <div class="journal-body">
      <h3 class="journal-title">{title}</h3>
      <p class="journal-excerpt">{excerpt}</p>
      <footer class="journal-meta">
        <time datetime={date.toISOString()} class="journal-date">{dateFormatted}</time>
        <span class="journal-reading">{readingTime} min de lecture</span>
      </footer>
    </div>
  </a>
</article>

<style>
  .journal-card {
    background: var(--noir-card);
    border: 1px solid rgba(197, 165, 114, 0.15);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .journal-card:hover { border-color: rgba(197, 165, 114, 0.35); }

  .journal-link { display: block; text-decoration: none; }

  .journal-image {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--noir-surface);
  }

  .journal-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .journal-card:hover .journal-image img { transform: scale(1.03); }

  .journal-image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--noir-surface);
  }

  .journal-category {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--noir);
    background: var(--gold);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .journal-body { padding: 1.25rem; }

  .journal-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--blanc);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .journal-excerpt {
    font-size: 0.875rem;
    color: var(--gris-texte);
    line-height: 1.6;
    margin-bottom: 1rem;
    max-width: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .journal-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .journal-date,
  .journal-reading {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--gris-muted);
    letter-spacing: 0.03em;
  }
</style>
