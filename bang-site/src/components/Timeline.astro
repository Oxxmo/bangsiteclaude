---
const events = [
  {
    year: '2023',
    title: 'Naissance de bang.',
    desc: 'Scott lance l\'atelier avec une conviction simple : chaque montre doit raconter une histoire unique. Les premières pièces naissent dans l\'atelier de Dissay.',
  },
  {
    year: '2024',
    title: 'Premières livraisons & témoignages',
    desc: 'Les premières montres trouvent leurs propriétaires. Le bouche-à-oreille fait son travail. La gamme Signature voit le jour avec le Trio Zanzibar.',
  },
  {
    year: '2025',
    title: 'Le Club & le Journal',
    desc: 'Lancement du programme Club pour les clients fidèles. Le Journal dépasse 2 000 lecteurs mensuels. La communauté bang. prend forme.',
  },
  {
    year: '2026',
    title: '77+ créations livrées',
    desc: 'L\'atelier atteint plus de 77 pièces livrées. La limite de 7 commandes par mois reste le garde-fou d\'une qualité sans compromis.',
  },
];
---

<div class="timeline">
  {events.map((event, i) => (
    <div class="timeline-item">
      <div class="timeline-marker">
        <span class="timeline-year">{event.year}</span>
        <div class="timeline-dot" aria-hidden="true"></div>
      </div>
      <div class="timeline-content">
        <h3 class="timeline-title">{event.title}</h3>
        <p class="timeline-desc">{event.desc}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5.5rem;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(197, 165, 114, 0.2);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    align-items: start;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-marker {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    padding-top: 0.15rem;
  }

  .timeline-year {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    border: 2px solid var(--noir);
    outline: 1px solid var(--gold);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .timeline-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--blanc);
    margin-bottom: 0.5rem;
  }

  .timeline-desc {
    font-size: 0.9rem;
    color: var(--gris-texte);
    line-height: 1.6;
    max-width: 50ch;
  }

  @media (max-width: 600px) {
    .timeline::before { display: none; }
    .timeline-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .timeline-marker { justify-content: flex-start; }
  }
</style>
