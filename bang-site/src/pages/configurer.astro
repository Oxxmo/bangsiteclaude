---
import Base from '../layouts/Base.astro';
import BarreRarete from '../components/BarreRarete.astro';
---

<Base
  title="Configurer ma montre — bang."
  description="Créez votre montre sur mesure en 6 étapes : cadran, aiguilles, boîtier, mouvement, bracelet et signature. Prix indicatif en temps réel."
>
  <div class="configurateur-page">
    <header class="conf-header">
      <div class="container">
        <p class="conf-eyebrow">Le configurateur</p>
        <h1>Créez votre montre</h1>
        <p class="conf-subtitle">Choisissez chaque composant, visualisez le prix indicatif en temps réel. Aucune obligation d'achat.</p>
        <div style="margin-top: 1.5rem;">
          <BarreRarete />
        </div>
      </div>
    </header>

    <div class="conf-steps">
      <div class="container">
        <div class="steps-nav" role="tablist" aria-label="Étapes du configurateur">
          {[
            { num: '01', label: 'Cadran' },
            { num: '02', label: 'Aiguilles' },
            { num: '03', label: 'Boîtier' },
            { num: '04', label: 'Mouvement' },
            { num: '05', label: 'Bracelet' },
            { num: '06', label: 'Signature' },
          ].map((step, i) => (
            <button
              class={`step-btn ${i === 0 ? 'step-btn--active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              <span class="step-btn-num">{step.num}</span>
              <span class="step-btn-label">{step.label}</span>
            </button>
          ))}
        </div>

        <div class="conf-workspace">
          <div class="conf-options">
            <div class="conf-placeholder">
              <p class="conf-placeholder-text">
                Le configurateur interactif est en cours de développement.<br />
                En attendant, <a href="/contact">contactez-nous directement</a> pour démarrer votre projet.
              </p>
              <a href="/contact" class="btn-primary" style="margin-top: 1.5rem;">Démarrer mon projet</a>
            </div>
          </div>

          <aside class="conf-summary">
            <div class="summary-card">
              <h2 class="summary-title">Votre configuration</h2>
              <div class="summary-badge">
                <span class="badge badge-initiale">Gamme Initiale</span>
              </div>
              <div class="summary-price">
                <span class="price-label">Estimation indicative</span>
                <span class="price-val">à partir de 320 €</span>
              </div>
              <p class="summary-note">Prix indicatif, hors frais de livraison. Le devis définitif est établi lors du brief.</p>
              <div class="summary-actions">
                <button class="btn-secondary" style="width: 100%;" disabled>Sauvegarder ma config</button>
                <a href="https://calendly.com/bang-atelier" target="_blank" rel="noopener noreferrer" class="btn-primary" style="width: 100%; text-align: center; margin-top: 0.5rem;">Réserver un brief</a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .configurateur-page {
    min-height: 80vh;
  }

  .conf-header {
    padding-block: 3rem;
    border-bottom: 1px solid rgba(197, 165, 114, 0.15);
    background: var(--noir-surface);
  }

  .conf-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
    max-width: none;
  }

  .conf-subtitle {
    color: var(--gris-texte);
    margin-top: 0.5rem;
    max-width: 55ch;
  }

  .conf-steps { padding-block: 2rem; }

  .steps-nav {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(197, 165, 114, 0.1);
    margin-bottom: 2rem;
  }

  .step-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    background: var(--noir-card);
    border: 1px solid rgba(197, 165, 114, 0.15);
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s ease;
    flex-shrink: 0;
  }

  .step-btn--active {
    border-color: var(--gold);
  }

  .step-btn-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--gris-muted);
    letter-spacing: 0.08em;
  }

  .step-btn-label {
    font-family: 'League Spartan', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--blanc);
  }

  .step-btn--active .step-btn-num { color: var(--gold); }

  .conf-workspace {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .conf-workspace { grid-template-columns: 1fr; }
    .conf-summary { order: -1; }
  }

  .conf-placeholder {
    background: var(--noir-surface);
    border: 1px dashed rgba(197, 165, 114, 0.3);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .conf-placeholder-text {
    color: var(--gris-texte);
    line-height: 1.7;
    max-width: 40ch;
  }

  .conf-placeholder-text a { color: var(--gold); }

  .summary-card {
    background: var(--noir-card);
    border: 1px solid rgba(197, 165, 114, 0.15);
    border-radius: 12px;
    padding: 1.5rem;
    position: sticky;
    top: 80px;
  }

  .summary-title {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--blanc);
  }

  .summary-badge { margin-bottom: 1rem; }

  .summary-price {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(197, 165, 114, 0.1);
    border-bottom: 1px solid rgba(197, 165, 114, 0.1);
    margin-bottom: 1rem;
  }

  .price-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gris-muted);
  }

  .price-val {
    font-family: 'League Spartan', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--gold);
  }

  .summary-note {
    font-size: 0.75rem;
    color: var(--gris-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .summary-actions { display: flex; flex-direction: column; }
</style>
