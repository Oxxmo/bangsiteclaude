{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "redirects": [
    { "source": "/simulateur", "destination": "/configurer", "permanent": true },
    { "source": "/simulateur/", "destination": "/configurer", "permanent": true },
    { "source": "/atelier", "destination": "/realisations", "permanent": true },
    { "source": "/atelier/", "destination": "/realisations", "permanent": true },
    { "source": "/notre-histoire", "destination": "/la-maison", "permanent": true },
    { "source": "/notre-histoire/", "destination": "/la-maison", "permanent": true },
    { "source": "/a-propos", "destination": "/la-maison", "permanent": true },
    { "source": "/a-propos/", "destination": "/la-maison", "permanent": true },
    { "source": "/catalogue", "destination": "/configurer", "permanent": true },
    { "source": "/catalogue/", "destination": "/configurer", "permanent": true },
    { "source": "/verify", "destination": "/passeport", "permanent": true },
    { "source": "/verify/", "destination": "/passeport", "permanent": true },
    { "source": "/lejournalbang", "destination": "/journal", "permanent": true },
    { "source": "/lejournalbang/", "destination": "/journal", "permanent": true },
    { "source": "/category/culture", "destination": "/journal?cat=culture", "permanent": true },
    { "source": "/category/style", "destination": "/journal?cat=style", "permanent": true },
    { "source": "/category/atelier", "destination": "/journal?cat=atelier", "permanent": true },
    { "source": "/category/mecanique", "destination": "/journal?cat=mecanique", "permanent": true },
    { "source": "/mentionslegales", "destination": "/mentions-legales", "permanent": true },
    { "source": "/mentionslegales/", "destination": "/mentions-legales", "permanent": true },
    { "source": "/politique-de-confidentialite", "destination": "/confidentialite", "permanent": true },
    { "source": "/politique-de-confidentialite/", "destination": "/confidentialite", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    }
  ]
}
